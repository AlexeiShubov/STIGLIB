# This repo ships a UPM package (package.json/Scripts live at the root).
# Get latest base template from https://github.com/github/gitignore/blob/main/Unity.gitignore

# Unity-generated folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/
*.log

# This repo ships a UPM package, not a full project - never commit
# the local sandbox test project's own config (see STIGLIB-TestProject)
/[Pp]ackages/
/[Pp]roject[Ss]ettings/

# Stray root .meta files Unity generates if this repo is ever opened
# directly as a project (package.json at root confuses the Package Manager)
/Assets.meta
/Library.meta
/Logs.meta
/Packages.meta
/ProjectSettings.meta
/Temp.meta
/UserSettings.meta

# IDE / tooling caches
.vs/
.gradle/
ExportedObj/
.consulo/
*.DotSettings.user

# Autogenerated VS/MD/Rider solution and project files
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crash / diagnostics
sysinfo.txt
crashlytics-build.properties
mono_crash.*

# Build output (in case the package is exported/tested as a build)
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app
